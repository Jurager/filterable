{
    "name": "jurager/filterable",
    "description": "Laravel package for building complex eloquent filters in a simple, structured way",
    "keywords": ["laravel", "filter", "eloquent", "json-api", "eav", "nestedset"],
    "license": "MIT",
    "authors": [
        {
            "name": "Yuri Gerassimov",
            "email": "jurager01@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "laravel/pint": "^1.0"
    },
    "suggest": {
        "jurager/eav": "Provides entity-attribute-value attribute filtering",
        "aimeos/laravel-nestedset": "Required for descendants filtering"
    },
    "autoload": {
        "psr-4": {
            "Jurager\\Filterable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jurager\\Filterable\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jurager\\Filterable\\FilterableServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
